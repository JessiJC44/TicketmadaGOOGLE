{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account information and roles",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photo": { "type": "string", "format": "uri" },
        "role": { "type": "string", "enum": ["user", "organizer", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "Ticket": {
      "title": "Event Ticket",
      "description": "A ticket purchased by a user for an event",
      "type": "object",
      "properties": {
        "id_code": { "type": "string", "description": "Unique ticket code (QR)" },
        "userId": { "type": "string" },
        "eventId": { "type": "string" },
        "eventName": { "type": "string" },
        "zoneName": { "type": "string" },
        "seatInfo": { "type": "string" },
        "price": { "type": "number" },
        "status": { "type": "string", "enum": ["valid", "used", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id_code", "userId", "eventId", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Public and private user profile data"
    },
    "/tickets/{ticketId}": {
      "schema": "Ticket",
      "description": "Individual ticket records"
    }
  }
}
