{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account information and roles",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["user", "organizer", "admin", "superadmin", "buyer"] },
        "provider": { "type": "string" },
        "lastLogin": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "Event": {
      "title": "Event",
      "description": "Event details",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "organizerId": { "type": "string" },
        "organizerName": { "type": "string" },
        "category": { "type": "string" },
        "venue": { "type": "string" },
        "city": { "type": "string" },
        "dateStart": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["active", "draft", "cancelled", "finished"] },
        "capacity": { "type": "number" },
        "ticketsSold": { "type": "number" },
        "totalRevenue": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "organizerId", "status"]
    },
    "Ticket": {
      "title": "Event Ticket",
      "description": "A ticket purchased by a user for an event",
      "type": "object",
      "properties": {
        "id_code": { "type": "string" },
        "userId": { "type": "string" },
        "eventId": { "type": "string" },
        "eventName": { "type": "string" },
        "price": { "type": "number" },
        "status": { "type": "string", "enum": ["valid", "used", "cancelled", "refunded"] },
        "scannedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id_code", "userId", "eventId", "status"]
    },
    "OrganizerApplication": {
      "title": "Organizer Application",
      "description": "Application to become an organizer",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "organizationName": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "fullName", "email", "status"]
    },
    "PromoCode": {
      "title": "Promo Code",
      "description": "Discount code",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "organizerId": { "type": "string" },
        "eventId": { "type": "string" },
        "discountType": { "type": "string", "enum": ["percentage", "fixed"] },
        "discountValue": { "type": "number" },
        "usageLimit": { "type": "number" },
        "usedCount": { "type": "number" },
        "active": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["code", "discountType", "discountValue", "active"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/events/{eventId}": {
      "schema": "Event",
      "description": "Event records"
    },
    "/tickets/{ticketId}": {
      "schema": "Ticket",
      "description": "Ticket records"
    },
    "/organizer_applications/{applicationId}": {
      "schema": "OrganizerApplication",
      "description": "Organizer signups"
    },
    "/promo_codes/{promoId}": {
      "schema": "PromoCode",
      "description": "Discount codes"
    }
  }
}
