rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definitions
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function isEmailVerified() { return request.auth.token.email_verified == true; }

    // --- Users Collection ---
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'name', 'email', 'role', 'createdAt', 'updatedAt'])
          && data.keys().size() == 6
          && data.uid == request.auth.uid
          && data.name is string && data.name.size() <= 100
          && data.email is string && data.email.size() <= 100
          && data.role in ['user', 'organizer']
          && data.createdAt is timestamp
          && data.updatedAt is timestamp;
      }

      allow get: if isSignedIn();
      allow list: if false; // Users shouldn't be listable
      
      allow create: if isOwner(userId) 
        && isValidUser(incoming())
        && incoming().createdAt == request.time;
        
      allow update: if isOwner(userId)
        && isValidUser(incoming())
        && incoming().uid == existing().uid
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && (
          // Action: Profile Update
          incoming().diff(existing()).affectedKeys().hasOnly(['name', 'photo', 'updatedAt']) ||
          // Action: Role Switch (only if not admin)
          incoming().diff(existing()).affectedKeys().hasOnly(['role', 'updatedAt'])
        );
    }

    // --- Tickets Collection ---
    match /tickets/{ticketId} {
      function isValidTicket(data) {
        return data.keys().hasAll(['id_code', 'userId', 'eventId', 'eventName', 'zoneName', 'price', 'status', 'createdAt'])
          && data.keys().size() == 8
          && data.id_code is string && data.id_code.size() <= 64
          && data.userId == request.auth.uid
          && data.eventId is string && data.eventId.size() <= 64
          && data.status in ['valid', 'used', 'cancelled']
          && data.price is number
          && data.createdAt is timestamp;
      }

      allow get: if isSignedIn() && (isOwner(existing().userId));
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid);
      
      allow create: if isSignedIn()
        && isValidTicket(incoming())
        && incoming().createdAt == request.time;
        
      allow update: if false; // Tickets are usually immutable via client once created
      allow delete: if false;
    }
  }
}
