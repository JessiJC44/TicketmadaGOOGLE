rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function getUserData() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function hasRole(role) { return isSignedIn() && getUserData().role == role; }
    function isSuperAdmin() { return hasRole('superadmin'); }
    function isAdmin() { return hasRole('admin') || isSuperAdmin(); }
    
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // User profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && request.resource.data.role == 'buyer';
      allow update: if isOwner(userId) || isSuperAdmin();
    }

    // Events
    match /events/{eventId} {
      allow read: if true; // Public events
      allow create, update: if hasRole('organizer') || isAdmin();
      allow delete: if isAdmin();
    }

    // Tickets
    match /tickets/{ticketId} {
      allow read: if isOwner(resource.data.userId) || hasRole('organizer') || isAdmin();
      allow create: if isSignedIn();
      allow update: if isAdmin();
    }

    // Organizer Applications
    match /organizer_applications/{applicationId} {
      allow read, update: if isSuperAdmin() || isOwner(resource.data.uid);
      allow create: if isSignedIn();
    }

    // Promo Codes
    match /promo_codes/{promoId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() || hasRole('organizer');
    }
  }
}
